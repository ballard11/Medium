<table class="toolbox-table table table-striped">
  <thead>
    <tr>
      <th>Tool Name</th>
      <th>Category</th>
      <th>My Verdict</th>
      <th>Link</th>
    </tr>
  </thead>
  <tbody>
    <% for (const item of items) { %>
    <tr>
      <td>
        <a href="<%- item.path %>"><strong><%= item.title %></strong></a>
        <% if (item.description) { %>
          <br><small class="text-muted"><%= item.description %></small>
        <% } %>
      </td>
      <td>
        <% if (item.categories) { %>
          <% item.categories.filter(cat => cat !== 'tool').forEach(function(category) { %>
            <span class="badge bg-secondary"><%= category %></span>
          <% }); %>
        <% } %>
      </td>
      <td>
        <%
          let badgeClass = 'bg-info';
          if (item.status === 'Active Use') badgeClass = 'bg-success';
          if (item.status === 'Archived') badgeClass = 'bg-secondary';
        %>
        <span class="badge <%= badgeClass %>"><%= item.status || 'Unknown' %></span>
      </td>
      <td>
        <% if (item.link) { %>
          <a href="<%= item.link %>" target="_blank" class="btn btn-sm btn-outline-primary">
            Visit →
          </a>
        <% } %>
      </td>
    </tr>
    <% } %>
  </tbody>
</table>

<style>
.toolbox-table {
  margin-top: 2em;
}

.toolbox-table td {
  vertical-align: middle;
}

.toolbox-table .badge {
  margin-right: 0.3em;
}
</style>
