# --- DATA & SECRETS (Highest Priority) ---
# Never upload raw datasets or API credentials
data/
raw_data/
datasets/
scraped_data/
*.csv
*.json
*.xlsx
*.parquet
*.db
*.sqlite
.env
.env.*
!.env.example
auth.yaml
secrets.py
config.ini
credentials.json
*.key
*.pem

# --- QUARTO & BUILD ARTIFACTS ---
# These are generated files; no need to track them
.quarto/
_site/
# _freeze/ is intentionally tracked — frozen outputs allow CI to deploy
# posts with live API calls without re-executing them in GitHub Actions.
_publish.yml
*.html

# --- PYTHON & JUPYTER ---
# Ignore environment and temp files
__pycache__/
*.py[cod]
*$py.class
.venv/
venv/
ENV/
env/
*.ipynb
.ipynb_checkpoints/
*.ipynb_checkpoints
.pytest_cache/
.coverage
htmlcov/

# --- PROPRIETARY CODE & MODELS ---
# Keep your competitive edge local
scratch/
proprietary/
private/
models/
*.pkl
*.pickle
*.h5
*.pt
*.pth
*.ckpt

# --- OPERATING SYSTEM ---
# Hide system-specific junk
.DS_Store
Thumbs.db
desktop.ini

# --- IDE & EDITOR ---
.vscode/
.idea/
*.swp
*.swo
*~

# --- LOGS & TEMP FILES ---
*.log
logs/
tmp/
temp/
*.tmp
*.bak
*.backup
